{
  "rewrites": [
    {
      "source": "/api/texlive/:match*",
      "destination": "https://texlive.net/:match*"
    },
    {
      "source": "/api/openrouter/:match*",
      "destination": "https://openrouter.ai/:match*"
    },
    {
      "source": "/latexcgi/:match*",
      "destination": "https://texlive.net/latexcgi/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
